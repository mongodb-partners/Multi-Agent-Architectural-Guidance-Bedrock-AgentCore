#!/bin/bash


# Deployment environment + project identity
export ENVIRONMENT="dev"
export PROJECT_NAME="mongodb-multiagent3"


# ─────────────────────────────────────────────────────────────────────────────
# AWS authentication
#
# AUTH_MODE declares HOW this deployment will authenticate. The deploy scripts
# validate the credential block accordingly via deploy/scripts/_aws-auth.sh.
#   - iam : long-lived IAM user access keys (default; back-compat)
#   - sts : assumed-role / SSO / OIDC temporary credentials
#           (use this when your org/account prohibits IAM users)
# See deploy/iam/README.md for the STS role + trust-policy setup.
# ─────────────────────────────────────────────────────────────────────────────
export AUTH_MODE="iam"   # change to "sts" if your org disallows IAM users

# ── AUTH_MODE=iam block ─────────────────────────────────────────────────────
# Long-lived IAM user access keys. Required when AUTH_MODE=iam.
export AWS_ACCESS_KEY_ID="..."
export AWS_SECRET_ACCESS_KEY="..."

# ── AUTH_MODE=sts block (uncomment + flip AUTH_MODE above to test) ──────────
# Raw STS env vars — from `aws sts assume-role` / `aws configure export-credentials`:
# export AWS_ACCESS_KEY_ID="..."
# export AWS_SECRET_ACCESS_KEY="..."
# export AWS_SESSION_TOKEN="..."
# Verify after sourcing this file:
# aws sts get-caller-identity   # ARN should start with arn:aws:sts::...:assumed-role/

# Belt-and-suspenders: clear any stale credential state so the env-var keys
# above are unambiguously what the AWS CLI + SDKs use.
#
# AWS_PROFILE — always unset. This template authenticates via env vars
#   (AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY [+ AWS_SESSION_TOKEN]), and a
#   stale AWS_PROFILE in your shell would silently shadow them under both
#   AUTH_MODE=iam and AUTH_MODE=sts. The named-profile STS path (option (b)
#   in deploy/scripts/_aws-auth.sh) is a different flow that doesn't use
#   this file.
# AWS_SESSION_TOKEN — only unset under AUTH_MODE=iam (mixing it with static
#   IAM keys is the #1 source of "wrong creds used" bugs). Under
#   AUTH_MODE=sts the token is REQUIRED, so we preserve it.
unset AWS_PROFILE
if [[ "${AUTH_MODE:-iam}" == "iam" ]]; then
  unset AWS_SESSION_TOKEN
fi

# ── continue with common block ──────────

# AWS_REGION is the canonical name used by all deploy scripts.
# AWS_DEFAULT_REGION is the name used by the AWS CLI + SDKs.
# Both must point to the same value.
export AWS_REGION="us-east-1"
export AWS_DEFAULT_REGION="$AWS_REGION"

# Shared network identity — drives the SSM prefix, the network state key, and
# the resource Name prefix for the per-region shared VPC + Atlas connectivity
# stack (envs/network). Multiple per-project deployments in the same region
# point at the same SHARED_VPC_NAME and read SSM-published VPC/subnet IDs.
export SHARED_VPC_NAME="mongodb-shared-network"

# ──────────────────────────────────────────────────────────────────────────────
# Connectivity mode — privatelink (default) or peering. PrivateLink and VPC
# peering are MUTUALLY EXCLUSIVE per account; switching modes requires
# destroy + redeploy (see destroy.sh and deploy-network.sh --allow-mode-switch).
#
# Use the matching orchestrator:
#   privatelink → ./deploy/deploy-full-with-privatelink.sh
#   peering     → ./deploy/deploy-full-with-vpc-peering.sh
#
# The orchestrators export NETWORK_MODE before delegating, so leaving this
# blank is fine when you use them; set it explicitly only if you call
# deploy-network.sh / deploy-project.sh directly.
# ──────────────────────────────────────────────────────────────────────────────
export NETWORK_MODE="privatelink"           # privatelink | peering

# Atlas-side CIDR for VPC peering mode. Must not overlap VPC_CIDR (10.0.0.0/16
# by default). Atlas's default network container CIDR is 192.168.248.0/21,
# which is reserved by Atlas for peering and is safe to reuse. Ignored when
# NETWORK_MODE=privatelink.

# VPC peering requires this CIDR to be unique across Atlas peers in the project.
export VPC_CIDR="10.42.0.0/16"

# Atlas network container CIDR (peering deploys). Must not overlap VPC_CIDR.
export ATLAS_PEERING_CIDR="192.168.248.0/21"

# Shared-resource prefix — drives the env-scoped name of the shared CloudWatch
# log groups (/${SHARED_RESOURCE_PREFIX}/<env>/{api,ui,mcp,agentcore,otel}),
# the fleet/mongo/cost/atlas dashboards (${SHARED_RESOURCE_PREFIX}-fleet-<env>,
# etc.), all 7 fleet alarms + 2 atlas alarms, the 4 metric filters, and the
# 5 Logs-Insights query definitions provisioned by envs/shared. Multiple
# per-project envs/ec2 stacks in the same (account, region, environment)
# share one set of these resources, so the prefix must be stable.
export SHARED_RESOURCE_PREFIX="multiagent"
# Also exported as TF_VAR_shared_resource_prefix so a manual `terraform apply`
# in envs/shared picks it up without waiting for deploy-shared.sh to wire it.
export TF_VAR_shared_resource_prefix="$SHARED_RESOURCE_PREFIX"

# Shared CloudWatch retention. API and OTel logs keep the longer audit/debug
# window; UI, MCP, and shared AgentCore placeholder logs stay short-lived.
export API_LOG_RETENTION_DAYS="30"
export AUX_LOG_RETENTION_DAYS="7"
export OTEL_LOG_RETENTION_DAYS="$API_LOG_RETENTION_DAYS"
# Optional: dedicated S3 bucket for Knowledge Base source documents.
# Unset (default) → KB docs live in the shared bucket:
#   s3://${PROJECT_NAME}-${ENVIRONMENT}-<account_id>/kb-docs/docs/
# Set → Terraform creates/uses this bucket instead (name must be globally
# unique, lowercase, 3–63 chars). Written to terraform.tfvars as
# kb_docs_bucket_name by deploy-project.sh, deploy-local.sh, and destroy.sh.
# Terraform remote state always stays on the shared bucket above.
# export KB_DOCS_BUCKET="${PROJECT_NAME}-${ENVIRONMENT}-kb-docs-<account_id>"
 
# MongoDB Atlas — provider (Atlas Terraform provider reads these)
export MONGODB_ATLAS_PUBLIC_KEY="..."
export MONGODB_ATLAS_PRIVATE_KEY="..."
 
# Atlas project / identity — both the Atlas-provider name and the Phase-2
# mongodb-atlas module variable name are exported so either consumer works.
export TF_VAR_mongodb_atlas_org_id="..."
export TF_VAR_mongodb_atlas_project_id="..."
export TF_VAR_atlas_project_id="$TF_VAR_mongodb_atlas_project_id"
 
# Atlas DB credentials
# Names are project+env-derived so multiple deployments can share a single Atlas
# project without colliding on the database user or database name.
# Mongo identifiers can't contain "-", so we underscore-normalize PROJECT_NAME.
_PROJECT_SLUG="$(echo "${PROJECT_NAME}" | tr '-' '_')"
export ATLAS_DB_USER="${_PROJECT_SLUG}_${ENVIRONMENT}_user"
export ATLAS_DB_NAME="${_PROJECT_SLUG}_${ENVIRONMENT}"
unset _PROJECT_SLUG
 
# MCP write gate. Default off (read-only). Set to 1 to let the mongodb-mcp
# AgentCore Runtime perform insertOne / updateOne. Destructive ops
# (delete*, drop*, replaceOne) stay refused regardless. deploy-project.sh reads
# this and bakes MONGODB_ALLOW_WRITE into the MCP runtime on a full redeploy.
# export MONGODB_ALLOW_WRITE=1

# Atlas DB password — canonical name used by bedrock-kb + envs/ec2 + envs/local.
# Legacy TF_VAR_mongodb_password retained for anything still referencing it.
export TF_VAR_atlas_db_password="..."
export TF_VAR_mongodb_password="$TF_VAR_atlas_db_password"
 
# TF_VAR_atlas_srv_host — intentionally UNSET in Phase 1 (bedrock_kb deferred).
# Phase 2's mongodb-atlas module provisions the cluster and its output will be
# wired in by editing envs/{ec2,local}/main.tf. If you need to source an
# existing cluster manually, export it here:
# export TF_VAR_atlas_srv_host="cluster0.xxxxx.mongodb.net"
 
# Developer laptop public IP (/32) — used by deploy to sync Atlas allowlists:
#   • Organization API key access list (Admin API / preflight / Terraform)
#   • Project network access list (peering mode — local-exec seeding from laptop)
# Developer laptop public IP (/32 CIDR) — used by deploy-network.sh (peering mode)
# for the Atlas project network access list, and referenced by preflight when
# Atlas returns IP_ADDRESS_NOT_ON_ACCESS_LIST on API key probes.
# Auto-detected via checkip on `source .env`; override when on VPN.
export OPERATOR_IP_CIDR="$(curl -fsS --max-time 8 https://checkip.amazonaws.com)/32"
# Legacy/terraform alias — keep in sync with OPERATOR_IP_CIDR.
export TF_VAR_my_ip="${OPERATOR_IP_CIDR}"

# ─────────────────────────────────────────────────────────────────────────────
# Voyage AI on SageMaker (embedding provider — Voyage multimodal default)
# ─────────────────────────────────────────────────────────────────────────────
# The default stack uses voyage-multimodal-3 on SageMaker. When
# VOYAGE_MODEL_PACKAGE_ARN is set, deploy.sh provisions a SageMaker real-time
# endpoint hosting that model and wires VOYAGE_SAGEMAKER_ENDPOINT into BOTH
# the EC2 API (.env.live) and all 4 AgentCore Runtimes. Leave the ARN empty
# to skip the endpoint entirely and fall back to Bedrock Titan v2 (1024-d).
#
# To enable (one-time per AWS account):
#   1. In the AWS console, subscribe to the MongoDB Voyage AI listing:
#        https://aws.amazon.com/marketplace/pp/prodview-hrid2zxusacxy
#      Click "Continue to Subscribe" → "Accept Offer".
#   2. Open SageMaker Service Quotas → request "ml.g6.xlarge for endpoint usage"
#      ≥ 1 if it's still 0. Usually approved instantly.
#   3. Copy the region-specific SageMaker model-package ARN for the subscribed
#      multimodal listing into VOYAGE_MODEL_PACKAGE_ARN below. After that, the
#      full deploy provisions the endpoint and re-seeds embeddings.
#
# Cost: ~$2.25/hr software + ~$0.20/hr infra (ml.g6.xlarge real-time, per the
# Marketplace listing). Stop/destroy the endpoint when not in use;
# deploy/scripts/destroy.sh handles this when you tear down the project envs.
#
# Output dimension defaults to 1024 (`VOYAGE_DEFAULT_EMBEDDING_DIMS` in the TS
# SSOT `api/src/adapters/voyage-embedding.ts`). It is configurable via
# VOYAGE_OUTPUT_DIM (see below): the adapter's `getVoyageEmbeddingDims()` is the
# single env reader, and Bash / Python / Terraform derive from it via the SSOT
# bridge (`voyage_embedding_dims`, `voyage-print.ts dims`). Only
# voyage-multimodal-3.5 supports non-1024 Matryoshka dims (256/512/1024/2048);
# voyage-multimodal-3 is 1024-only. Changing the dim re-sizes the Atlas vector
# index and requires re-embedding (the next `_seed-embeddings.sh` run
# auto-detects the drift via SSM + an in-Mongo fingerprint and rewires).
#
# Request envelope is multimodal-only — `buildVoyageRequestBody` in the TS
# SSOT always emits `{ "inputs": [{ "content": [...] }], ... }`. The legacy
# `{ "input": [...] }` branch was removed in the multimodal-only migration
# (Voyage Multimodal Integration plan, May 2026). The only supported Voyage
# listings are `voyage-multimodal-3` and `voyage-multimodal-3.5`.
#
# See docs/reference/voyage.md (the canonical Voyage configuration reference)
# and docs/advanced/deploy-tweak-guide.md §4 for the full flow.
# ─────────────────────────────────────────────────────────────────────────────
# Embedding provider selection — MANDATORY, strict mode (no silent fallback).
# The API refuses to boot if this is empty or unset. There is no implicit
# default and no cross-provider failover at runtime — `voyage` calls only
# Voyage, `titan` calls only Bedrock Titan. Switching providers requires a
# redeploy (and a backfill: `bun db-seeding/reembed-mismatched.ts`).
#
#   "titan"       : Skips SageMaker entirely and
#                   uses amazon.titan-embed-text-v2:0 on Bedrock. No
#                   Marketplace subscription required. This is an explicit
#                   non-default provider — deploy.sh logs a banner and
#                   writes EMBEDDINGS_PROVIDER=titan into deploy-manifest.json
#                   so it is never silent.
#   "voyage"      : Requires VOYAGE_MODEL_PACKAGE_ARN pointing at one of the
#                   two supported multimodal listings — voyage-multimodal-3
#                   (default) or voyage-multimodal-3.5. Text-only Voyage
#                   models (voyage-3*, voyage-4*, voyage-code-*, …) are
#                   refused at preflight; deploy validation and
#                   pf_check_voyage_marketplace_model_matches_arn both gate
#                   on `voyage_supported_models` from the bash SSOT.
export EMBEDDINGS_PROVIDER="voyage"

# Marketplace ARN is region+subscription scoped — never hard-code in source
# control. Copy the ARN for your accepted multimodal Marketplace model package
# into this line. Ignored when EMBEDDINGS_PROVIDER=titan; required
# (and validated to be a Voyage multimodal model package) when
# EMBEDDINGS_PROVIDER=voyage.
export VOYAGE_MODEL_PACKAGE_ARN="..."
# Pinned to voyage-multimodal-3 — the only supported alternative is
# voyage-multimodal-3.5 (both 1024-d). The deploy scripts keep this model name
# intact for validation, then normalize the SageMaker endpoint suffix.
export VOYAGE_MARKETPLACE_MODEL="voyage-multimodal-3"
# voyage-multimodal-3 is GPU-only on Marketplace. ml.g6.xlarge is the
# recommended real-time instance. CPU instances (m5/c5) fail at endpoint creation.
export VOYAGE_INSTANCE_TYPE="ml.g6.xlarge"
# Endpoint name suffix is normalized in code before SageMaker sees it, so
# dotted model-derived values such as voyage-multimodal-3.5 become
# voyage-multimodal-3-5 at endpoint creation time.
export TF_VAR_voyage_endpoint_name_suffix="voyage-multimodal-3"
# Embedding output dimension. Leave unset for the default 1024
# (VOYAGE_DEFAULT_EMBEDDING_DIMS). Allowed values: 256, 512, 1024, 2048 — and
# ONLY voyage-multimodal-3.5 emits non-1024 (voyage-multimodal-3 is 1024-only;
# the API/seed will refuse a non-1024 value with that model). Whatever you set
# here is validated by the TypeScript SSOT; deploy scripts derive Terraform's
# internal var.voyage_output_dim from it so the Atlas vector index
# (numDimensions, sized by db-seeding/seed-indexes.ts) matches the vectors.
# Changing this on an existing deployment requires re-embedding — the next
# `_seed-embeddings.sh` run detects the SSM/fingerprint dim drift and rewires;
# manual fallback is `bun db-seeding/reembed-mismatched.ts --apply`.
# export VOYAGE_OUTPUT_DIM="1024"
#
# NOTE: there is no VOYAGE_REQUEST_FORMAT env var. The request envelope is built
# by `buildVoyageRequestBody` (TS SSOT). `output_dimension` is added to the
# envelope automatically (and only) when VOYAGE_OUTPUT_DIM resolves to a
# non-default dim. Adding VOYAGE_REQUEST_FORMAT back will fail
# `voyage-ssot-guard.test.ts`.

# ─────────────────────────────────────────────────────────────────────────────
# LTM / trace value gating
# ─────────────────────────────────────────────────────────────────────────────
# Long-term-memory facts and chat-message mirrors are personal data. By
# default the trace doc stored in MongoDB and shown in the Trace Viewer
# replaces every fact/queryText/factCandidate/factsExtracted string with
# the literal "<redacted>". The Trace Viewer surfaces a banner explaining
# the gate.
#
# Flip via THIS file then re-run `./deploy/deploy-api.sh` (and
# `./deploy/deploy-agents.sh` if AgentCore Runtimes also need raw values
# — they do, because the inner agent loop runs there when
# ORCHESTRATOR_MODE=runtime). NEVER hand-edit /opt/multiagent/.env.live
# on EC2 — the next deploy will overwrite it.
#
#   MEMORY_TRACE_VALUES=1 → raw fact text in trace events.
#   TRACE_PROMPT_BODY=1   → prompt.assembled.body attached (full system
#                            prompt incl. ## Relevant prior context).
#   TRACE_REDACT=1        → blanket redactDeep pass over every payload
#                            (independent of MEMORY_TRACE_VALUES).
#
# Default (left unset / explicitly 0): safe, redacted.
# export MEMORY_TRACE_VALUES=0
# export TRACE_PROMPT_BODY=0
# export TRACE_REDACT=0
**/*.tfplan
**/.tfplan*
**/*.binary
**/backend.hcl
**/terraform.tfvars
**/*.auto.tfvars.json
# Module provisioner sidecar JSON (Atlas PL/peering, AgentCore, KB, etc.)
deploy/terraform/modules/**/.*.json
# Lambda zip build artifact
deploy/terraform/modules/lambda-mcp/.build/

# Python
__pycache__/
*.py[cod]
*$py.class
# pytest (ui/tests/, e2e-smoke/)

**/test-results/**/*.png

# Deploy / destroy script artifacts (written at repo root by deploy.sh + destroy.sh)
destroy-reports/
deploy-reports/
deploy-manifest*.json
.agent-config-refresh-token
# Troubleshooting infra script — persisted bucket / run state (not Terraform tfstate)
.infra-state.sh

# Python virtual environments
.venv/
venv/
*.egg-info/

# Stale / archived files
bin/

# Streamlit local secrets
**/.streamlit/secrets.toml

# Docker Compose local overrides
compose.override.y*ml

# Credentials (local PEM/key material at repo root)
*.pem
*.p12
/*.key


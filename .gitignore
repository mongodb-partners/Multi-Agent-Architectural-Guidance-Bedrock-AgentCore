vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Terraform — state, lock sidecars, workspace state dirs, and CLI cache (.terraform/)
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.lock.info
**/terraform.tfstate.d/
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

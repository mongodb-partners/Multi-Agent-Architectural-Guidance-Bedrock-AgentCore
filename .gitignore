# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Runtime secrets / credentials — never commit these
backupEnv.sh
.env.live

# Terraform — state, lock sidecars, workspace state dirs, and CLI cache (.terraform/)
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.lock.info
**/terraform.tfstate.d/
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Terraform runtime-generated files (created by deploy scripts at apply time)
**/*.tfplan
**/.tfplan*
**/*.binary
**/backend.hcl
**/terraform.tfvars
deploy/terraform/envs/ec2/agents.auto.tfvars.json
# Per-module runtime state (Bedrock KB, AgentCore Memory, AgentCore Gateway)
deploy/terraform/modules/**/.kb-state.json
deploy/terraform/modules/**/.memory-state.json
deploy/terraform/modules/**/.gateway-state.json
# AgentCore runtime ephemeral state files
deploy/terraform/modules/agentcore-agent-runtime/.runtime-state-*.json
# Atlas PrivateLink shared-service discovery cache (keyed by project + region)
deploy/terraform/modules/atlas-privatelink/.pl-*.json
# Lambda zip build artifact
deploy/terraform/modules/lambda-mcp/.build/

# Python
__pycache__/
*.py[cod]
*$py.class

# Bun / Node
api/node_modules/
e2e/node_modules/

# Playwright — test artifacts (results, reports, media, last-run state)
test-results/
**/test-results/
**/playwright-report/
**/blob-report/
**/demo-videos/
**/.last-run.json
**/*.webm
**/*.mp4
# Keep *.png only for test-results dirs (screenshots are artifacts, not source)
**/test-results/**/*.png

# Deploy / destroy script artifacts (written at repo root by deploy.sh + destroy.sh)
destroy-reports/
deploy-reports/
deploy-manifest*.json
.agent-config-refresh-token
# Troubleshooting infra script — persisted bucket / run state (not Terraform tfstate)
.infra-state.sh

# Python virtual environments
.venv/
venv/
*.egg-info/

# Stale / archived files
bin/

# macOS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
e2e/playwright.nova.config.ts

<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="request-flow" name="End-to-End Request Flow">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="End-to-End Request Flow — Customer asks &quot;Where is my order ORD-1234?&quot;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1500" height="40" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="ll-user" value="User (UI)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="140" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-api" value="Hono API on EC2" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="160" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-mem" value="AgentCore Memory" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="160" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-orch" value="Orchestrator Runtime" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="180" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-spec" value="Specialist Runtime&#xa;(order-management)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="80" width="200" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-bed" value="Bedrock&#xa;Claude Sonnet 4.6" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="80" width="160" height="900" as="geometry" />
        </mxCell>
        <mxCell id="ll-lam" value="Lambda MCP&#xa;mongodb-mcp" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="80" width="160" height="900" as="geometry" />
        </mxCell>

        <!-- Step 1: POST /chat -->
        <mxCell id="m1" value="POST /chat&#xa;{message, sessionId}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#0066CC;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ll-user" target="ll-api">
          <mxGeometry y="170" relative="1" as="geometry">
            <mxPoint x="80" y="170" as="sourcePoint" />
            <mxPoint x="280" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 2: append user msg + read priorTurns -->
        <mxCell id="m2" value="appendUserMessage()&#xa;getSession() → priorTurns" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#666666;dashed=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="220" as="sourcePoint" />
            <mxPoint x="370" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 3: read long-term memory -->
        <mxCell id="m3" value="ListEventsCommand&#xa;(userId, agentId)" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="ll-api" target="ll-mem">
          <mxGeometry y="270" relative="1" as="geometry">
            <mxPoint x="280" y="270" as="sourcePoint" />
            <mxPoint x="500" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="last 5 turns" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#9673a6;dashed=1;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-mem" target="ll-api">
          <mxGeometry y="295" relative="1" as="geometry">
            <mxPoint x="500" y="295" as="sourcePoint" />
            <mxPoint x="280" y="295" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 4: InvokeAgentRuntime to orchestrator -->
        <mxCell id="m5" value="InvokeAgentRuntime(orchestratorArn)&#xa;{message, priorTurns, memoryContext}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#1A3DCB;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ll-api" target="ll-orch">
          <mxGeometry y="340" relative="1" as="geometry">
            <mxPoint x="280" y="340" as="sourcePoint" />
            <mxPoint x="720" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 5: Orchestrator decides -->
        <mxCell id="m6" value="runChatStream(orchestrator)&#xa;classify → handoff: order-management" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#1A3DCB;dashed=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="810" y="380" as="sourcePoint" />
            <mxPoint x="810" y="400" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 6: Orchestrator -> specialist -->
        <mxCell id="m7" value="InvokeAgentRuntime(orderMgmtArn)" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#1A3DCB;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ll-orch" target="ll-spec">
          <mxGeometry y="430" relative="1" as="geometry">
            <mxPoint x="720" y="430" as="sourcePoint" />
            <mxPoint x="960" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 7: Specialist runs Strands agent -->
        <mxCell id="m8" value="runChatStream(order-management)&#xa;Strands agent loop starts" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#82b366;dashed=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1060" y="470" as="sourcePoint" />
            <mxPoint x="1060" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 8: Specialist -> Bedrock -->
        <mxCell id="m9" value="InvokeModel (Claude reasoning)" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#27ae60;fontSize=10;" edge="1" parent="1" source="ll-spec" target="ll-bed">
          <mxGeometry y="520" relative="1" as="geometry">
            <mxPoint x="960" y="520" as="sourcePoint" />
            <mxPoint x="1220" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="tool_use: mongodb_query&#xa;{collection: orders, filter: {orderId: ORD-1234}}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#27ae60;dashed=1;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-bed" target="ll-spec">
          <mxGeometry y="560" relative="1" as="geometry">
            <mxPoint x="1220" y="560" as="sourcePoint" />
            <mxPoint x="960" y="560" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 9: Specialist -> Lambda -->
        <mxCell id="m11" value="lambda:InvokeFunction&#xa;{tool: mongodb_query, args: {...}}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#d79b00;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ll-spec" target="ll-lam">
          <mxGeometry y="600" relative="1" as="geometry">
            <mxPoint x="960" y="600" as="sourcePoint" />
            <mxPoint x="1430" y="600" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 10: Lambda -> Atlas (implicit) -->
        <mxCell id="m12" value="MongoDB query via PrivateLink&#xa;→ Atlas mongod 1024-1026" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#d79b00;dashed=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1530" y="640" as="sourcePoint" />
            <mxPoint x="1530" y="660" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 11: Lambda -> Specialist (result) -->
        <mxCell id="m13" value="{count: 1, documents: [{orderId, status, tracking}]}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#d79b00;dashed=1;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-lam" target="ll-spec">
          <mxGeometry y="690" relative="1" as="geometry">
            <mxPoint x="1430" y="690" as="sourcePoint" />
            <mxPoint x="960" y="690" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 12: Specialist -> Bedrock again -->
        <mxCell id="m14" value="InvokeModel (compose answer)" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#27ae60;fontSize=10;" edge="1" parent="1" source="ll-spec" target="ll-bed">
          <mxGeometry y="730" relative="1" as="geometry">
            <mxPoint x="960" y="730" as="sourcePoint" />
            <mxPoint x="1220" y="730" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m15" value="text: &quot;Your order ORD-1234 is in transit...&quot;" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#27ae60;dashed=1;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-bed" target="ll-spec">
          <mxGeometry y="760" relative="1" as="geometry">
            <mxPoint x="1220" y="760" as="sourcePoint" />
            <mxPoint x="960" y="760" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 13: Specialist -> Orchestrator -->
        <mxCell id="m16" value="{response, agentId: order-management}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#1A3DCB;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-spec" target="ll-orch">
          <mxGeometry y="800" relative="1" as="geometry">
            <mxPoint x="960" y="800" as="sourcePoint" />
            <mxPoint x="720" y="800" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 14: Orchestrator -> API -->
        <mxCell id="m17" value="{response, handoffs: [order-management]}" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#1A3DCB;strokeWidth=2;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-orch" target="ll-api">
          <mxGeometry y="830" relative="1" as="geometry">
            <mxPoint x="720" y="830" as="sourcePoint" />
            <mxPoint x="280" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 15: write long-term memory -->
        <mxCell id="m18" value="CreateEventCommand&#xa;(USER + ASSISTANT pair)" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="ll-api" target="ll-mem">
          <mxGeometry y="870" relative="1" as="geometry">
            <mxPoint x="280" y="870" as="sourcePoint" />
            <mxPoint x="500" y="870" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 16: SSE to user -->
        <mxCell id="m19" value="SSE: agent_info → token → handoff → done" style="html=1;verticalAlign=bottom;startSize=8;endSize=8;strokeColor=#0066CC;strokeWidth=2;endArrow=open;fontSize=10;" edge="1" parent="1" source="ll-api" target="ll-user">
          <mxGeometry y="930" relative="1" as="geometry">
            <mxPoint x="280" y="930" as="sourcePoint" />
            <mxPoint x="80" y="930" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Footer note -->
        <mxCell id="note" value="Notes:&#xa;• InvokeAgentRuntime is request/response, not streaming. The full reply is wrapped in a single SSE 'token' event for UI compatibility.&#xa;• Mongo tools always go through the AgentCore Gateway MCP endpoint (MCP_SERVER_URL = AGENTCORE_GATEWAY_URL), authenticated with the caller's Cognito JWT.&#xa;• Long-term memory only writes if userId (JWT sub claim) is known and agent has memory.longTerm: true." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="1010" width="1500" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

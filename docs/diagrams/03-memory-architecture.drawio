<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="memory-arch" name="Memory Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1654" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Memory Architecture — Short-Term (Session) and Long-Term (Cross-Session)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1500" height="40" as="geometry" />
        </mxCell>

        <!-- API box -->
        <mxCell id="api" value="Hono API on EC2 — api/src/routes/chat.ts" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1540" height="220" as="geometry" />
        </mxCell>

        <mxCell id="req" value="POST /chat&#xa;{message, sessionId, agentId}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Short-term path -->
        <mxCell id="st-step1" value="1. appendUserMessage(sessionId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="140" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="st-step2" value="2. getSession() → priorTurns[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="190" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="st-step3" value="3. inject priorTurns into AgentCore payload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="240" width="220" height="40" as="geometry" />
        </mxCell>

        <!-- Long-term path -->
        <mxCell id="lt-step1" value="A. if agent.memory.longTerm + userId&#xa;readLongTermMemory(userId, agentId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="140" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lt-step2" value="B. inject memoryContext (last 5 turns)&#xa;as text into AgentCore payload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="200" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lt-step3" value="C. after reply: writeLongTermMemory()&#xa;(USER+ASSISTANT pair)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="250" width="240" height="40" as="geometry" />
        </mxCell>

        <mxCell id="invoke" value="InvokeAgentRuntime(orchestratorArn)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="190" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="resp" value="response → SSE token + done&#xa;back to UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="190" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- Short-term storage -->
        <mxCell id="st-box" value="Short-Term Memory (Session)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="700" height="280" as="geometry" />
        </mxCell>

        <mxCell id="st-source" value="api/src/lib/session-store.ts" style="text;html=1;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="st-mem" value="In-Memory Map&#xa;(default)&#xa;&#xa;Map&lt;sessionId, SessionRecord&gt;&#xa;Per-process · lost on restart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="450" width="280" height="180" as="geometry" />
        </mxCell>

        <mxCell id="st-mongo" value="MongoDB Persistent&#xa;(opt-in)&#xa;&#xa;collection: chat_sessions&#xa;PERSIST_CHAT_SESSIONS=1&#xa;Survives API restart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="450" width="280" height="180" as="geometry" />
        </mxCell>

        <!-- Long-term storage -->
        <mxCell id="lt-box" value="Long-Term Memory (Cross-Session)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="380" width="800" height="280" as="geometry" />
        </mxCell>

        <mxCell id="lt-source" value="api/src/lib/long-term-memory.ts" style="text;html=1;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="410" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lt-ac" value="AgentCore Memory Store (default in EC2)&#xa;&#xa;BedrockAgentCoreClient&#xa;CreateEvent / ListEvents&#xa;sessionId = userId::agentId&#xa;TTL 30 days&#xa;&#xa;Triggered when&#xa;AGENTCORE_MEMORY_STORE_ID is set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="450" width="370" height="200" as="geometry" />
        </mxCell>

        <mxCell id="lt-mongo" value="MongoDB long-term hybrid memory&#xa;&#xa;collections: agent_memory_facts + chat_messages&#xa;TTL index on ts (default 90 days)&#xa;hybrid: $vectorSearch + $search BM25&#xa;RRF + recency decay + MMR&#xa;&#xa;Direct Mongo path for API-owned LTM reads/writes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1210" y="450" width="370" height="200" as="geometry" />
        </mxCell>

        <!-- Activation rules -->
        <mxCell id="rules-box" value="Activation Rules" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="1540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="rules" value="Short-Term: Always on. Every /chat call appends user + assistant messages.&#xa;&#xa;Long-Term: Activated per agent via frontmatter — currently enabled on troubleshooting.agent.md, order-management.agent.md, product-recommendation.agent.md (memory.shortTerm: true, memory.longTerm: true).&#xa;Orchestrator does NOT have long-term memory (not needed — it only routes).&#xa;&#xa;Long-term memory keys on userId = JWT sub claim. Auth is mandatory: assertJwksAuthConfigured() in api/src/index.ts refuses to boot the API without AUTH_JWKS_URI + AUTH_ISSUER, so every authenticated request has a userId.&#xa;&#xa;Tunables: MEMORY_INJECT_TURNS (default 5)  ·  MEMORY_TTL_DAYS (default 90, MongoDB only)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="730" width="1500" height="120" as="geometry" />
        </mxCell>

        <!-- Connectors -->
        <mxCell id="c1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;" edge="1" parent="1" source="req" target="st-step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;" edge="1" parent="1" source="req" target="lt-step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;" edge="1" parent="1" source="lt-step2" target="invoke">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;" edge="1" parent="1" source="invoke" target="resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;dashed=1;" edge="1" parent="1" source="st-step1" target="st-mem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;dashed=1;" edge="1" parent="1" source="st-step2" target="st-mongo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="lt-step1" target="lt-ac">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="lt-step3" target="lt-ac">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

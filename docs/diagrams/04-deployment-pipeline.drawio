<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="deploy-pipeline" name="Deployment Pipeline">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1654" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Deployment Pipeline — deploy/scripts/deploy.sh --auto-approve  (~20-25 min)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1500" height="40" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="Triggered locally or from GitHub Actions. Runs against AWS account 483874864688 in us-east-1." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1500" height="20" as="geometry" />
        </mxCell>

        <!-- Phase 1: Preflight -->
        <mxCell id="p1" value="1. Preflight" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1d" value="Check CLI prereqs (aws, terraform, bun, python3, zip)&#xa;Validate AWS + Atlas creds&#xa;Set deployment_mode = code (default)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Phase 2: Bootstrap -->
        <mxCell id="p2" value="2. Bootstrap S3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="120" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2d" value="Create S3 bucket for tfstate&#xa;bedrock-ma-use1-dev-483874864688&#xa;Encrypted, versioned" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="270" y="200" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Phase 3: Build artifact -->
        <mxCell id="p3" value="3. Build agent-runtime&#xa;artifact (S3 code mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3d" value="esbuild bundle TypeScript&#xa;→ agent-runtime-code.js (CJS, NODE_22)&#xa;zip with config/ assets&#xa;upload to s3://bucket/artifacts/agentcore-runtime/{git-sha}/deployment_package.zip" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="200" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Phase 4: Terraform -->
        <mxCell id="p4" value="4. Terraform apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="120" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p4d" value="VPC · EC2 · ECR · Cognito · KB&#xa;Atlas M10 · PrivateLink · Lambda MCP&#xa;AgentCore Memory · Gateway · 4 Runtimes&#xa;CloudWatch · Secrets Manager&#xa;~15-20 min (Atlas slowest)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="200" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Phase 5: Seed -->
        <mxCell id="p5" value="5. Atlas seed&#xa;(first-time only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="950" y="120" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p5d" value="Check core collections present&#xa;If empty: bun run db-seeding/seed-all.ts&#xa;customers, products, orders, troubleshooting_docs, indexes" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="950" y="200" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Phase 6: Lambda URI -->
        <mxCell id="p6" value="6. Lambda MCP URI fix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1170" y="120" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p6d" value="Fetch Atlas direct PrivateLink URI&#xa;(mongod listener 1024-1026, not SRV)&#xa;Update Lambda env via update-function-configuration&#xa;Set MONGODB_URI" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1170" y="200" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Phase 7: Docker -->
        <mxCell id="p7" value="7. Docker build + push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1390" y="120" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p7d" value="Build api + ui (linux/amd64)&#xa;Tag :latest + :sha-{commit}&#xa;Push to ECR repos" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="200" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Phase 8: Inject env -->
        <mxCell id="p8" value="8. Inject runtime env" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p8d" value="terraform output → all ARNs/IDs/URLs&#xa;build dynamic env JSON&#xa;bedrock-agentcore-control update-agent-runtime × 4&#xa;injects: MONGODB_URI, KB_ID, MEMORY_STORE_ID,&#xa;LAMBDA_MCP_FUNCTION_NAME, specialist ARNs (orchestrator)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 9: Write .env.live -->
        <mxCell id="p9" value="9. .env.live → EC2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p9d" value="Generate .env.live with:&#xa;CHAT_MODE=live · TOOL_HOSTING_MODE=lambda&#xa;ORCHESTRATOR_MODE=runtime&#xa;AGENTCORE_ORCHESTRATOR_ARN=...&#xa;Copy to EC2 /opt/multiagent/.env.live via SSM (mode 600)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="460" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 10: Restart EC2 -->
        <mxCell id="p10" value="10. Restart services" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p10d" value="SSM send-command:&#xa;ECR login → docker pull api+ui&#xa;systemctl restart multiagent-{api,ui}&#xa;(no MCP service — Lambda now)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="460" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 11: Health check -->
        <mxCell id="p11" value="11. Health check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p11d" value="curl http://EC2_IP:3000/health&#xa;Retry 120× / 5s interval&#xa;Verify mongodb, longTermMemory, mcpServer all 'connected'" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="810" y="460" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 12: Smoke test -->
        <mxCell id="p12" value="12. Smoke test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p12d" value="POST /chat with 'return item'&#xa;Verify: orchestrator → specialist&#xa;handoff event in SSE stream&#xa;No error events" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="460" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 13: Manifest -->
        <mxCell id="p13" value="13. deploy-manifest.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1310" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p13d" value="Persist deploy artifacts:&#xa;all ARNs · IDs · URLs · IPs&#xa;Cognito · Atlas · ECR · Lambda · Memory" style="text;html=1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1310" y="460" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Quick update path -->
        <mxCell id="qu-box" value="Code-only Update (skip Terraform, ~3-5 min)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="1540" height="200" as="geometry" />
        </mxCell>

        <mxCell id="qu1" value="Build + push&#xa;docker-build-push.sh&#xa;api/ui only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="690" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qu2" value="(Optional) Re-zip + upload&#xa;agent-runtime artifact&#xa;to S3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="690" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qu3" value="(Optional) update-agent-runtime&#xa;to point to new S3 versionId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="690" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qu4" value="SSM send-command&#xa;docker pull + restart on EC2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="690" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qu5" value="curl /health&#xa;verify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="690" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qu-note" value="No SSH key needed — SSM Session Manager handles all remote ops. The EC2 IAM instance profile has AmazonSSMManagedInstanceCore." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="100" y="790" width="1480" height="20" as="geometry" />
        </mxCell>


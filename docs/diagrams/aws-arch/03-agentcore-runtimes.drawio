        <mxCell id="api" value="🖥 Hono API&#xa;on EC2&#xa;(the entry point)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="160" height="90" as="geometry"/>
        </mxCell>

<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="ac-runtimes" name="03 · AgentCore Runtimes">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="1">

        <mxCell id="title" value="AgentCore Runtimes — 4 managed containers, one shared codebase" style="text;html=1;align=center;fontSize=20;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="15" width="1080" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sub" value="All 4 runtimes run the same agent-runtime-code.js bundle. The AGENT_ID environment variable tells each container which agent to be." style="text;html=1;align=center;fontSize=11;strokeColor=none;fillColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="48" width="1080" height="18" as="geometry"/>
        </mxCell>


          <mxGeometry x="840" y="500" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Atlas (outside) -->
        <mxCell id="atlas-border" value="MongoDB Atlas (outside AWS VPC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#27ae60;strokeWidth=2;dashed=1;fontSize=11;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="220" y="760" width="900" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="atlas" value="🍃 MongoDB Atlas M10&#xa;bedrock-ma-use1-dev.dcysxk.mongodb.net&#xa;TCP listeners on ports 1024, 1025, 1026 (PrivateLink forwarding)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="790" width="500" height="60" as="geometry"/>
        </mxCell>

        <!-- AgentCore (outside VPC, managed) -->
        <mxCell id="ac-border" value="AgentCore managed service (public network, not in VPC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A3DCB;strokeWidth=2;dashed=1;fontSize=11;fontStyle=1;verticalAlign=top;align=right;" vertex="1" parent="1">
          <mxGeometry x="640" y="220" width="460" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="ac-note" value="AgentCore Runtimes run on&#xa;AWS-managed infrastructure.&#xa;They are NOT inside your VPC.&#xa;They call Lambda via public&#xa;lambda.us-east-1.amazonaws.com&#xa;(AWS backbone, not open internet)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1A3DCB;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="255" width="250" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="ac-icon" value="🎯 orchestrator runtime&#xa;🔧 troubleshooting runtime&#xa;📦 order-management runtime&#xa;⭐ product-rec runtime" style="text;html=1;fontSize=10;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="930" y="255" width="160" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <!-- Internet → IGW -->
        <mxCell id="e1" value="HTTPS :3000 / :8501" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0066CC;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="inet" target="igw">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- IGW → EC2 -->
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0066CC;strokeWidth=2;" edge="1" parent="1" source="igw" target="ec2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- EC2 → AgentCore (public) -->
        <mxCell id="e3" value="InvokeAgentRuntime (HTTPS, SigV4)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1A3DCB;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ec2" target="ac-border">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- AgentCore → Lambda -->
        <mxCell id="e4" value="lambda:InvokeFunction (HTTPS, SigV4)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="ac-border" target="lam">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Lambda → VPC Endpoint -->
        <mxCell id="e5" value="TCP 1024-1026" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="lam" target="vpce">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Route 53 → VPC Endpoint -->
        <mxCell id="e6" value="DNS CNAME resolution" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;fontSize=10;" edge="1" parent="1" source="r53" target="vpce">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- VPC Endpoint → Atlas -->
        <mxCell id="e7" value="PrivateLink tunnel (AWS backbone)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27ae60;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="vpce" target="atlas">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Why PrivateLink note -->
        <mxCell id="pl-why" value="Why PrivateLink? MongoDB credentials never travel over the public internet. The connection goes EC2 → Lambda (AWS backbone) → VPC Endpoint → Atlas (PrivateLink tunnel). Atlas sees a private IP." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="220" y="870" width="900" height="40" as="geometry"/>
        </mxCell>
